{
  "includeCoAuthoredBy": false,
  "hooks": {
    "PreToolUse": [
      {
        "matcher": "Bash",
        "hooks": [
          {
            "type": "command",
            "command": "bash .claude/hooks/pre-commit-review.sh",
            "if": "Bash(git commit*)",
            "statusMessage": "checking /review-pr marker before commit"
          }
        ]
      }
    ]
  }
}
